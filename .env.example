# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/calendly_clone
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calendly_clone
DB_USER=postgres
DB_PASSWORD=password

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration (if needed for authentication)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Vercel Deployment Variables
# When deploying to Vercel, set these in your Vercel project settings:
# DATABASE_URL - Your PostgreSQL database URL (e.g., from Supabase, Neon, or Railway)
# FRONTEND_URL - Your deployed frontend URL (e.g., https://your-app.vercel.app)
