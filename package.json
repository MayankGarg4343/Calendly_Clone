{
  "name": "calendly-clone",
  "version": "1.0.0",
  "description": "A complete Calendly clone built with React.js, Node.js, Express, and PostgreSQL",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm run dev",
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start"
  },
  "keywords": [
    "calendly",
    "clone",
    "react",
    "nodejs",
    "express",
    "postgresql",
    "booking",
    "scheduling"
  ],
  "author": "Mayank Garg",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
